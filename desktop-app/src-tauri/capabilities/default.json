{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Loopback desktop shell: spawn the oolu sidecar only.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/oolu", "sidecar": true, "args": true }]
    }
  ]
}
