# Byte-compiled / optimized / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Distribution / packaging / editable installs
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local runtime data
*.db
*.sqlite
*.sqlite3
.oolu/
.workflow-gps/

# Node deps / Rust build output (also covered per-app under desktop-app/)
node_modules/
target/

# Secrets / local env (never commit API keys)
.env
.env.*
*.key
secrets.*

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Git bundles (transfer artifacts, never tracked)
*.bundle
.pyinstaller-work/
